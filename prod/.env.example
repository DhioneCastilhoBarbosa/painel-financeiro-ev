# FinanceDash — Variáveis de Ambiente de Produção
# 1. Copie este arquivo:  cp .env.example .env
# 2. Preencha todos os campos marcados com SUBSTITUIR
# 3. NUNCA versione o arquivo .env gerado
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de dados (container local) ─────────────────────────────────────────
# Para AWS RDS: comente o serviço db no docker-compose.yml e ajuste DATABASE_URL
POSTGRES_USER=financedash
POSTGRES_PASSWORD=SUBSTITUIR_SENHA_FORTE_BANCO
POSTGRES_DB=financedash
DATABASE_URL=postgresql+asyncpg://financedash:SUBSTITUIR_SENHA_FORTE_BANCO@db:5432/financedash

# Para AWS RDS (descomentar e substituir):
# DATABASE_URL=postgresql+asyncpg://financedash:SENHA@SEU-RDS.us-east-1.rds.amazonaws.com:5432/financedash

# ── Redis (container local) ───────────────────────────────────────────────────
# Para AWS ElastiCache: comente o serviço redis no docker-compose.yml e ajuste REDIS_URL
REDIS_PASSWORD=SUBSTITUIR_SENHA_FORTE_REDIS
REDIS_URL=redis://:SUBSTITUIR_SENHA_FORTE_REDIS@redis:6379/0

# Para AWS ElastiCache (descomentar e substituir):
# REDIS_URL=redis://SEU-ELASTICACHE.cache.amazonaws.com:6379/0

# ── Autenticação JWT ──────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=SUBSTITUIR_CHAVE_ALEATORIA_64_CHARS_HEX

# ── Aplicação ─────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
# Domínio(s) do frontend separados por vírgula (sem barra no final)
ALLOWED_ORIGINS=https://SEU_DOMINIO
# URL pública usada nos links de e-mail (verificação, reset de senha)
APP_URL=https://SEU_DOMINIO

# ── Storage de arquivos ───────────────────────────────────────────────────────
STORAGE_BACKEND=s3

# Cloudflare R2 (recomendado — sem custo de egress):
R2_ACCOUNT_ID=SUBSTITUIR
R2_ACCESS_KEY_ID=SUBSTITUIR
R2_SECRET_ACCESS_KEY=SUBSTITUIR
R2_BUCKET_NAME=financedash-uploads
R2_PUBLIC_URL=https://SUBSTITUIR.r2.dev

# AWS S3 (alternativa — descomentar se preferir S3):
# AWS_ACCESS_KEY_ID=SUBSTITUIR
# AWS_SECRET_ACCESS_KEY=SUBSTITUIR
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=financedash-uploads

# ── E-mail (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=SUBSTITUIR
EMAIL_FROM=FinanceDash <noreply@SEU_DOMINIO>

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_SUBSTITUIR
STRIPE_WEBHOOK_SECRET=whsec_SUBSTITUIR
STRIPE_PRICE_STARTER=price_SUBSTITUIR
STRIPE_PRICE_PRO=price_SUBSTITUIR

# ── Monitoramento (Sentry) ────────────────────────────────────────────────────
SENTRY_DSN=https://SUBSTITUIR@sentry.io/SUBSTITUIR
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0.05

# ── Segurança ─────────────────────────────────────────────────────────────────
# Protege o Swagger UI — acesse: https://SEU_DOMINIO/api/docs?token=VALOR
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
DOCS_ACCESS_TOKEN=SUBSTITUIR_TOKEN_ALEATORIO
