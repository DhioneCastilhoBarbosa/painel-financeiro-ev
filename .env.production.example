# ═════════════════════════════════════════════════════════════════════════════
# .env.production.example — Template de variáveis de ambiente para PRODUÇÃO
#
# INSTRUÇÕES:
#   1. Copie este arquivo:  cp .env.production.example .env.production
#   2. Preencha TODOS os valores marcados com <SUBSTITUIR>
#   3. NUNCA versione o arquivo .env.production (já está no .gitignore)
#   4. Use AWS Secrets Manager ou Parameter Store em vez de arquivo em produção
#
# Para gerar SECRET_KEY segura:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ═════════════════════════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────────────────────────
# Para Timescale Cloud: obtenha a connection string no painel do serviço
# Para RDS PostgreSQL com TimescaleDB: crie uma instância r7g.large+
POSTGRES_USER=financedash
POSTGRES_PASSWORD=<SUBSTITUIR: senha forte, ex. openssl rand -base64 32>
POSTGRES_DB=financedash

# Formato assíncrono — dentro do Compose use host `db` (porta interna 5432).
# Porta 5435 no host é só acesso externo (DBeaver, etc.).
DATABASE_URL=postgresql+asyncpg://financedash:<PASSWORD>@db:5432/financedash

# ─── Redis ────────────────────────────────────────────────────────────────────
# Dentro do Compose use host `redis` (porta interna 6379).
# Porta 6380 no host é só acesso externo.
REDIS_URL=redis://redis:6379/0

# ─── Autenticação JWT ────────────────────────────────────────────────────────
# CRÍTICO: gere com → python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<SUBSTITUIR: chave aleatória de 64 hex chars>
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# Domínio(s) do frontend separados por vírgula (CORS na API)
# Deploy atual por IP (docker-compose.prod.yml já define defaults):
ALLOWED_ORIGINS=http://54.159.164.244:3003,http://54.159.164.244
# Depois do domínio no Dokploy, troque por ex.:
# ALLOWED_ORIGINS=https://app.seudominio.com.br
# APP_URL=https://app.seudominio.com.br

# URL pública do frontend — usada nos links de e-mail (verify, reset, invite)
APP_URL=http://54.159.164.244:3003

# URL da API para o browser (build do Next.js — docker-compose.prod.yml)
# NEXT_PUBLIC_API_URL=http://54.159.164.244:8001

# ─── Storage de arquivos ─────────────────────────────────────────────────────
# Em produção use "s3" com Cloudflare R2 ou Amazon S3
STORAGE_BACKEND=s3
LOCAL_UPLOADS_DIR=./uploads

# Cloudflare R2 (compatível com S3)
R2_ACCOUNT_ID=<SUBSTITUIR: account ID do Cloudflare>
R2_ACCESS_KEY_ID=<SUBSTITUIR: R2 Access Key ID>
R2_SECRET_ACCESS_KEY=<SUBSTITUIR: R2 Secret Access Key>
R2_BUCKET_NAME=financedash-uploads
R2_PUBLIC_URL=https://<SUBSTITUIR>.r2.dev

# Se usar Amazon S3 diretamente (altere também storage_backend para s3):
# AWS_ACCESS_KEY_ID=<SUBSTITUIR>
# AWS_SECRET_ACCESS_KEY=<SUBSTITUIR>
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=financedash-uploads

# ─── E-mail (Resend) ─────────────────────────────────────────────────────────
# 1. Crie conta em resend.com
# 2. Adicione e verifique o domínio financedash.com.br (SPF + DKIM)
# 3. Crie uma API Key e cole abaixo
RESEND_API_KEY=<SUBSTITUIR: re_xxxxxxxxxxxxxxxxxxxxxxxx>
EMAIL_FROM=FinanceDash <noreply@financedash.com.br>

# ─── Stripe ──────────────────────────────────────────────────────────────────
# 1. Crie produtos no Stripe Dashboard (modo produção, não teste)
# 2. Crie preços recorrentes mensais para cada produto
# 3. Configure o webhook endpoint: https://app.financedash.com.br/api/v1/billing/webhook
# 4. Cole o webhook signing secret abaixo
STRIPE_SECRET_KEY=<SUBSTITUIR: sk_live_xxxxxxxxxxxxxxxx>
STRIPE_WEBHOOK_SECRET=<SUBSTITUIR: whsec_xxxxxxxxxxxxxxxx>
STRIPE_PRICE_STARTER=<SUBSTITUIR: price_xxxxxxxxxxxxxxxx>
STRIPE_PRICE_PRO=<SUBSTITUIR: price_xxxxxxxxxxxxxxxx>

# ─── Sentry (monitoramento de erros) ─────────────────────────────────────────
# 1. Crie projeto em sentry.io
# 2. Cole o DSN abaixo
SENTRY_DSN=<SUBSTITUIR: https://xxxxxxxx@oxxxxxxx.ingest.sentry.io/xxxxxxx>
# 5% dos requests com distributed tracing — bom equilíbrio custo/visibilidade
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0.05
