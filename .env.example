# FinanceDash — variáveis de ambiente (desenvolvimento local)
# Copie: cp .env.example .env
# Produção / Dokploy: use .env.production.example → .env.production
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (docker compose dev: porta 5433 no host) ───────────────────────
POSTGRES_USER=financedash
POSTGRES_PASSWORD=financedash_dev
POSTGRES_DB=financedash
DATABASE_URL=postgresql+asyncpg://financedash:financedash_dev@localhost:5433/financedash

# ─── Redis (docker compose dev: porta 6380 no host) ───────────────────────────
REDIS_URL=redis://localhost:6380/0

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Gere: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque_por_uma_chave_segura_de_32_chars_minimo
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000
APP_URL=http://localhost:3000

# Swagger em produção: ?token=VALOR (deixe vazio em dev)
DOCS_ACCESS_TOKEN=

# ─── Storage (local em dev | s3/R2 em produção) ───────────────────────────────
STORAGE_BACKEND=local
LOCAL_UPLOADS_DIR=./uploads
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=financedash-files
R2_PUBLIC_URL=

# ─── Email (Resend) — opcional em dev ─────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@financedash.com.br

# ─── Stripe — opcional em dev ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# ─── Sentry — opcional ────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0

# ─── Frontend (só se rodar web fora do Docker ou build manual) ───────────────
# NEXT_PUBLIC_API_URL=http://localhost:8000
